# You do not need to fill in anything here to run the app.
# Just leave this file empty (or skip creating .env at all), then
# paste your Floyo API key in the app when it asks for one.
#
# Everything below is optional and only useful for advanced setups.

# --- Shared-key mode (optional) ---
# Set both values below if you want to run a single Floyo key on the
# server and grant access to trusted users through a private token.
# Most people do not need this.

# FLOYO_API_KEY=flo_your_key_here
# APP_ACCESS_TOKEN=long_random_string_min_32_chars

# --- Overrides (rarely needed) ---
# FLOYO_API_BASE_URL=https://api.floyo.ai
# FLOYO_CDN_URL=https://cdn.floyo.ai

# Local backend port. Defaults to 8788.
# The Vite dev server reads this through vite.config.js, so the
# proxy will follow whatever you set here.
# PORT=8788
