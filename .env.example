# Required. Your Floyo API key. Used by the server for every Floyo call.
# The key is read on the backend only. The app does not accept a key from
# the browser, and never stores one in localStorage, sessionStorage, or
# cookies. Treat this file like a password store.
FLOYO_API_KEY=flo_paste_your_key_here

# --- Optional overrides ---
# Defaults are correct for production Floyo. Set these only if you point
# the app at a non-default Floyo environment.
# FLOYO_API_BASE_URL=https://api.floyo.ai
# FLOYO_CDN_URL=https://cdn.floyo.ai

# Local backend port. Defaults to 8788. The Vite dev server reads this
# too, so the dev proxy follows whichever port you set.
# PORT=8788
